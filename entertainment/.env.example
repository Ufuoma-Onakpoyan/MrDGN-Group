# Backend API URL for blog content
VITE_API_URL=http://localhost:3001

# Rebrand gate: when "true", only a black screen is shown; site is inaccessible.
# Set to "false" or omit to run the site normally.
VITE_REBRAND_MODE=false

# Optional message on the rebrand screen (default: "We're rebranding. Please check back soon.")
# VITE_REBRAND_MESSAGE=We're rebranding. See you soon.
