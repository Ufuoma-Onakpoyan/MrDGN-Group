# Backend API URL - required for products, blog, jobs, and contact form
# Without this, the site will show fallback/empty content
VITE_API_URL=http://localhost:3001

# Optional: Cloudinary cloud name (same as backend CLOUDINARY_CLOUD_NAME). If the API returns
# product image paths like mrdgn/product_images/xxx, the construction site will build full
# Cloudinary URLs so images load even before the backend expands them.
# VITE_CLOUDINARY_CLOUD_NAME=your_cloud_name
