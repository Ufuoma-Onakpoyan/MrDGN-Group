# Backend API URL for blog content - leave empty for empty blog
VITE_API_URL=http://localhost:3001

# Cloudinary cloud name (same as backend CLOUDINARY_CLOUD_NAME). Used to build the Duerents video URL (public id: duerents_1_ji1mp7).
# VITE_CLOUDINARY_CLOUD_NAME=your_cloud_name

# Optional: full URL for Duerents video. If set, overrides Cloudinary URL above.
# VITE_DUERENTS_VIDEO_URL=https://...
